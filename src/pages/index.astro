---
import Base from '../layouts/Base.astro';
import { getPostList } from '../lib/kv';
import defaultCover from '../assets/default-cover.svg';

let posts: any[] = [];
try {
  const kv = (Astro.locals as any).runtime?.env?.BLOG_KV;
  if (kv) posts = await getPostList(kv);
} catch {}
posts.sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Base title="fnet - 个人博客">
  <h1 style="font-size: 3rem; margin: 0 0 0.3rem; color: #f0f6fc; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">Funsh's Blog</h1>
  <p style="color: #b0b8c4; margin: 0 0 1.5rem; font-size: 0.95rem; text-shadow: 0 1px 4px rgba(0,0,0,0.5);">世界在我眼前展開，我會斬斷一切我所留戀</p>

  {posts.length === 0 ? (
    <p style="color: #8b949e; text-align: center; padding: 3rem 0;">还没有文章。</p>
  ) : (
    <div style="display: grid; gap: 1.5rem;">
      {posts.map((post: any) => {
        const tags = post.tags ? post.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
        return (
          <article class="post-card" style="border: 1px solid #30363d; border-radius: 10px; overflow: hidden; transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.4);">
            <a href={`/blog/${post.slug}`} style="display: block; text-decoration: none; color: inherit;">
              <div style="aspect-ratio: 16 / 9; background: #0d1117; overflow: hidden;">
                <img src={post.cover || defaultCover.src} alt={post.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;" loading="lazy" class="card-img" />
              </div>
              <div style="padding: 1.3rem; background: rgba(22,27,34,0.25); backdrop-filter: blur(10px);">
                <h2 style="margin: 0 0 0.1rem; font-size: 2rem; color: #58a6ff; transition: color 0.2s;">{post.title}</h2>
                {post.description && (
                  <p style="color: #c9d1d9; font-size: 0.9rem; line-height: 1.55; margin: 0 0 0.3rem;">{post.description}</p>
                )}
                <div style="display: flex; align-items: center; gap: 0.5rem; color: #8b949e; font-size: 0.8rem; margin-bottom: 0.5rem;">
                  <span>上传者：「{post.author || 'funsh'}」</span>
                  <time>{new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</time>
                </div>
                {tags.length > 0 && (
                  <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                    {tags.map((tag: string) => (
                      <span style="background: rgba(88,166,255,0.1); color: #58a6ff; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.78rem; border: 1px solid rgba(88,166,255,0.2);">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        )
      })}
    </div>
  )}
</Base>

<style>
  .post-card:hover { transform: translateY(-2px); border-color: #484f58; }
  .post-card:hover .card-img { transform: scale(1.03); }
  .post-card:hover h2 { color: #79c0ff; }
</style>
